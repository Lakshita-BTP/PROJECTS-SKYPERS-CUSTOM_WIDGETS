{
  "id": "com.max.fycomparison",
  "version": "1.0.13",
  "name": "FY Comparison Chart",
  "newInstancePrefix": "FYComparison",
  "vendor": "MAX",
  "supportsExport": true,
  "icon": "data:image/svg+xml;base64,",
  "webcomponents": [
    {
      "kind": "main",
      "tag": "com-max-fycomparison",
      "url": "https://cdn.jsdelivr.net/gh/Lakshita-BTP/PROJECTS-SKYPERS-CUSTOM_WIDGETS@main/05.%20FY_Wise_Invoiced/ChartFY_Invoices_V13.js",
      "integrity": "sha384-7Ej8QK9U2Zt8JQKXS1rHAeLCSY4qnDcrA1FWFCWJujyNenZ6cyLNOcCKAZwnH3JS"
    }
  ],
  "dataBindings": {
    "myDataBinding": {
      "feeds": [
        {
          "id": "dimensions",
          "type": "dimension",
          "description": "Financial Year"
        },
        {
          "id": "measures",
          "type": "mainStructureMember",
          "description": "Invoiced and Collected"
        }
      ]
    }
  },
  "properties": {},
